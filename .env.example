# ═══════════════════════════════════════════════════════════════════════
#  IUG Chatbot — نموذج إعدادات البيئة
#  انسخ هذا الملف إلى .env وعبّئ القيم الفعلية (لا ترفع .env إلى git أبدًا)
# ═══════════════════════════════════════════════════════════════════════

# ── MongoDB Atlas ─────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=iug_chatbot
UPLOADED_DB_NAME=uploaded_files

# ── نموذج المحادثة (Groq / OpenRouter — أي endpoint متوافق مع OpenAI) ─────
CHAT_API_MODEL=openai/gpt-oss-20b
CHAT_API_URL=https://openrouter.ai/api/v1/chat/completions
CHAT_API_KEY=sk-or-...

# ── نموذج الـ Embeddings (Jina) ───────────────────────────────────────────
EMBED_MODEL=jina-embeddings-v3
EMBED_API_URL=https://api.jina.ai/v1/embeddings
EMBED_API_KEY=jina_...

# ── RAG (اختياري) ────────────────────────────────────────────────────────
# Collections تُستثنى من الفهرسة (مفصولة بفواصل)
RAG_EXCLUDE_COLLECTIONS=
# backend حفظ فهرس المتجهات: disk (محلي) | mongo (للنشر — يبقى بعد كل نشر)
INDEX_BACKEND=disk
INDEX_CACHE_DIR=.index_cache
# backend سجل المحادثة: mongo (دائم، افتراضي) | memory (يُفقد عند إعادة التشغيل)
SESSION_BACKEND=mongo

# ── Caching (اختياري) ────────────────────────────────────────────────────
# كاش داخلي آمن: إجابات عامة فقط (لا يُخزَّن أي رد يعتمد على بيانات طالب خاصة)
CACHE_ENABLED=true
CACHE_ANSWER_TTL=3600      # عمر إجابة عامة (ثوانٍ)
CACHE_ANSWER_MAXSIZE=512   # أقصى عدد إجابات مخزّنة
CACHE_EMBED_TTL=86400      # عمر متجه سؤال مخزّن (ثوانٍ)
CACHE_EMBED_MAXSIZE=2048   # أقصى عدد متجهات مخزّنة

# ── المصادقة (JWT) ───────────────────────────────────────────────────────
# سرّ توقيع توكن الجلسة — ≥32 حرفاً قوياً وعشوائياً في الإنتاج (لا تشاركها)
# في production يرفض التطبيق الإقلاع بسرّ ضعيف/افتراضي (fail-closed)
JWT_SECRET=ضع-سراً-قوياً-عشوائياً-32-حرفاً-على-الأقل
JWT_EXPIRE_HOURS=12
# مفتاح الإدارة لعمليات تعديل قاعدة المعرفة (رفع/حذف ملفات، مسح الكاش)
# فارغ = تُرفض تلك العمليات تماماً حتى تضبطه
ADMIN_API_KEY=
# حدود المعدل (طلب/دقيقة): الشات لكل طالب، والدخول لكل IP
RATE_LIMIT_CHAT_PER_MIN=30
RATE_LIMIT_LOGIN_PER_MIN=10

# إنشاء الأدمن الأول من إعداد آمن فقط (لا توجد صفحة تسجيل أدمن عامة).
# بعد أول تشغيل وتغيير كلمة المرور، احذف كلمة المرور من إعدادات البيئة.
ADMIN_BOOTSTRAP_ID=ADMIN-001
ADMIN_BOOTSTRAP_PASSWORD=ضع-كلمة-مرور-مؤقتة-قوية
ADMIN_BOOTSTRAP_NAME=مدير النظام

# ── Logging (اختياري) ────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── طبقة الـ API (اختياري) ───────────────────────────────────────────────
# development: تظهر /docs — production: تُخفى
API_ENV=development
# false هو الخيار الآمن: صنّف الملفات القديمة من لوحة الأدمن قبل إتاحتها.
LEGACY_UNCATALOGUED_FILES_PUBLIC=false
API_HOST=127.0.0.1
API_PORT=8000
# origins الواجهة الأمامية مفصولة بفواصل، مثال: http://localhost:3000
API_CORS_ORIGINS=*

# Adaptive RAG v2: every final answer goes through the LLM.
LLM_ALWAYS_ANSWER=true
ANSWER_CACHE_ENABLED=false
PIPELINE_V2_ENABLED=true
HIERARCHICAL_CHUNKING_ENABLED=true
EVIDENCE_CONTRACT_ENABLED=true
RERANK_TIMEOUT_SECONDS=2.5
RERANK_CIRCUIT_FAILURES=2
RERANK_CIRCUIT_COOLDOWN_SECONDS=60
