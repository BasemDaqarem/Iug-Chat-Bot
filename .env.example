# ═══════════════════════════════════════════════════════════════════════
#  IUG Chatbot — نموذج إعدادات البيئة
#  انسخ هذا الملف إلى .env وعبّئ القيم الفعلية (لا ترفع .env إلى git أبدًا)
# ═══════════════════════════════════════════════════════════════════════

# ── MongoDB Atlas ─────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=iug_chatbot
UPLOADED_DB_NAME=uploaded_files

# ── نموذج المحادثة (Groq / OpenRouter — أي endpoint متوافق مع OpenAI) ─────
CHAT_API_MODEL=openai/gpt-oss-20b
CHAT_API_URL=https://openrouter.ai/api/v1/chat/completions
CHAT_API_KEY=sk-or-...

# ── نموذج الـ Embeddings (Jina) ───────────────────────────────────────────
EMBED_MODEL=jina-embeddings-v3
EMBED_API_URL=https://api.jina.ai/v1/embeddings
EMBED_API_KEY=jina_...

# ── RAG (اختياري) ────────────────────────────────────────────────────────
# Collections تُستثنى من الفهرسة (مفصولة بفواصل)
RAG_EXCLUDE_COLLECTIONS=
# مجلد كاش الفهارس على القرص (الافتراضي: .index_cache)
INDEX_CACHE_DIR=.index_cache

# ── Caching (اختياري) ────────────────────────────────────────────────────
# كاش داخلي آمن: إجابات عامة فقط (لا يُخزَّن أي رد يعتمد على بيانات طالب خاصة)
CACHE_ENABLED=true
CACHE_ANSWER_TTL=3600      # عمر إجابة عامة (ثوانٍ)
CACHE_ANSWER_MAXSIZE=512   # أقصى عدد إجابات مخزّنة
CACHE_EMBED_TTL=86400      # عمر متجه سؤال مخزّن (ثوانٍ)
CACHE_EMBED_MAXSIZE=2048   # أقصى عدد متجهات مخزّنة

# ── Logging (اختياري) ────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── طبقة الـ API (اختياري) ───────────────────────────────────────────────
# development: تظهر /docs — production: تُخفى
API_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
# origins الواجهة الأمامية مفصولة بفواصل، مثال: http://localhost:3000
API_CORS_ORIGINS=*
